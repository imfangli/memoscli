{
  "name": "memoscli",
  "version": "0.1.0",
  "description": "Local-first Markdown memo CLI backed by Git and webhooks.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "homepage": "https://github.com/imfangli/memoscli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imfangli/memoscli.git"
  },
  "bugs": {
    "url": "https://github.com/imfangli/memoscli/issues"
  },
  "keywords": [
    "memo",
    "markdown",
    "cli",
    "git",
    "webhook",
    "local-first"
  ],
  "packageManager": "pnpm@10.33.3",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "memo": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "prepack": "pnpm build",
    "release:check": "node scripts/check-release-version.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "gray-matter": "^4.0.3",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
