{
  "name": "memoscli",
  "version": "0.1.0",
  "description": "Local-first Markdown memo CLI backed by Git and webhooks.",
  "type": "module",
  "bin": {
    "momo": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
